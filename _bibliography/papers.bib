@article{vijay_physics-induced_2026,
	title = {A physics-induced surrogate modeling framework for lithium-ion battery electrode manufacturing},
	volume = {688},
	copyright = {All rights reserved},
	issn = {0378-7753},
	url = {https://www.sciencedirect.com/science/article/pii/S0378775326011663},
	doi = {10.1016/j.jpowsour.2026.240416},
	abstract = {The manufacturing of lithium-ion battery electrodes is a complex, multi-step process. The selection of manufacturing parameters at each stage directly affects the final microstructure of the electrode and, consequently, the electrochemical performance of the cell. Here, we demonstrate the application of our Physics-Induced Electrode (PIE) framework, comprising a set of Machine Learning (ML) models that represent key manufacturing steps: slurry, drying, and calendering. For each step, the ML model uses the coordinates of the particles (representing the active material and carbon-binder aggregates at the mesoscale), along with geometrical descriptors with physical properties, to predict the resulting particle displacement. The model predictions were evaluated using statistical metrics and were found to be significantly accurate. The predicted electrode microstructures were further assessed in terms of their properties and exhibited good agreement with those obtained from purely physics-based simulations. To enhance interpretability, SHapley Additive exPlanations (SHAP) were used to analyze the contribution of the input features to the model predictions. The SHAP analysis showed that the ML predictions capture trends consistent with physical intuition for the manufacturing step analyzed. The PIE framework offers a scalable and interpretable approach that can be integrated into digital solutions to support battery electrode manufacturing pilot lines.},
	urldate = {2026-06-28},
	journal = {Journal of Power Sources},
	author = {Vijay, Utkarsh and Fernandez, Francisco and Galvez-Aranda, Diego E. and Asch, Mark and Franco, Alejandro A.},
	month = oct,
	year = {2026},
	pages = {240416},
	}


@article{vijay_hybrid_2025,
	title = {A hybrid modelling approach coupling physics-based simulation and deep learning for battery electrode manufacturing simulations},
	volume = {75},
	issn = {2405-8297},
	url = {https://www.sciencedirect.com/science/article/pii/S2405829724007098},
	doi = {10.1016/j.ensm.2024.103883},
	abstract = {Lithium-ion battery (LIB) performance is significantly influenced by its manufacturing process. Manufacturing of an optimized electrode can incur high production costs such as high energy consumption, high scrap rates and emissions. This is due to the process that consists of a series of manufacturing steps presenting a complex interrelationship, thus limiting the understanding of performance as a function of manufacturing parameters. While several empirical and computational methods are employed for optimization, they are demanding in terms of resources such as materials or computational effort. By leveraging Deep Learning (DL), we can enhance our understanding of the complex manufacturing processes and accelerate its optimization. We propose a data-driven supervised DL methodology to complement physics-based LIB cathode manufacturing simulations. The trained DL-based predictive model integrates well into a manufacturing simulation framework to forecast cathode slurry microstructures. The DL model demonstrates robust predictive performance for LIB NMC-111 and LiFePO4–based slurries and slurries for a solid-state battery NMC-622/argyrodite composite electrode preparation. While the current work is focused on the electrode slurry preparation process, the proposed methodology has potential for application to drying and calendering steps. This approach will be helpful in streamlining lab-scale electrode manufacturing, and reducing errors, waste and resource consumption.},
	urldate = {2025-03-05},
	journal = {Energy Storage Materials},
	author = {Vijay, Utkarsh and Galvez-Aranda, Diego E. and Zanotto, Franco M. and Le-Dinh, Tan and Alabdali, Mohammed and Asch, Mark and Franco, Alejandro A.},
	month = feb,
	year = {2025},
	keywords = {Physics-based simulation, Electrode manufacturing process, Electrode microstructure, Li-ion batteries, Physics-informed deep learning},
	pages = {103883},
}


@article{vijay_surrogate_2025,
	title = {Surrogate {Modeling} of {Lithium}-{Ion} {Battery} {Electrode} {Manufacturing} by {Combining} {Physics}-{Based} {Simulation} and {Deep} {Learning}},
	volume = {8},
	copyright = {All rights reserved},
	issn = {2566-6223},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1002/batt.202500433},
	doi = {10.1002/batt.202500433},
	abstract = {Optimizing the manufacturing process of Lithium-Ion Batteries (LIB. Finding efficient approaches that accelerate and replace time-consuming, material scrap-expensive trials-and-error optimization methods is a key area of research. This work presents a comprehensive LIB electrode manufacturing framework that combines physics-based simulations with deep learning. This framework efficiently simulates the manufacturing process of LIB electrodes as a function of their formulation. This framework takes the form of a surrogate manufacturing model able to predict the impact of manufacturing parameters on the electrode microstructure and properties. The model is based on a regressor-inspired variational autoencoder method. The analysis of the data and the predicted electrode functional metrics demonstrates the consistency of the approach with an electrode manufacturing model developed on the basis of physics. The reported framework holds significant promise in paving near real time optimization of LIB electrode manufacturing and supporting the optimization of battery cell design in pilot lines.},
	language = {en},
	number = {12},
	urldate = {2026-06-28},
	journal = {Batteries \& Supercaps},
	author = {Vijay, Utkarsh and Fernandez, Francisco and Ben Hadj Ali, Siwar and Asch, Mark and Franco, Alejandro A.},
	year = {2025},
	note = {\_eprint: https://chemistry-europe.onlinelibrary.wiley.com/doi/pdf/10.1002/batt.202500433},
	keywords = {electrode microstructure, Li-ion batteries, physics-based simulation, physics-guided deep learning, surrogate manufacturing modeling},
	pages = {e202500433},
}


@misc{asch_cybercosm_2021,
	title = {Cybercosm: {New} {Foundations} for a {Converged} {Science} {Data} {Ecosystem}},
	copyright = {Creative Commons Attribution-NonCommercial-NoDerivatives 4.0 International License},
	shorttitle = {Cybercosm},
	url = {http://arxiv.org/abs/2105.10680},
	doi = {10.48550/arXiv.2105.10680},
	abstract = {Scientific communities naturally tend to organize around data ecosystems created by the combination of their observational devices, their data repositories, and the workflows essential to carry their research from observation to discovery. However, these legacy data ecosystems are now breaking down under the pressure of the exponential growth in the volume and velocity of these workflows, which are further complicated by the need to integrate the highly data intensive methods of the Artificial Intelligence revolution. Enabling ground breaking science that makes full use of this new, data saturated research environment will require distributed systems that support dramatically improved resource sharing, workflow portability and composability, and data ecosystem convergence. The Cybercosm vision presented in this white paper describes a radically different approach to the architecture of distributed systems for data-intensive science and its application workflows. As opposed to traditional models that restrict interoperability by hiving off storage, networking, and computing resources in separate technology silos, Cybercosm defines a minimally sufficient hypervisor as a spanning layer for its data plane that virtualizes and converges the local resources of the system's nodes in a fully interoperable manner. By building on a common, universal interface into which the problems that infect today's data-intensive workflows can be decomposed and attacked, Cybercosm aims to support scalable, portable and composable workflows that span and merge the distributed data ecosystems that characterize leading edge research communities today.},
	urldate = {2026-06-28},
	publisher = {arXiv},
	author = {Asch, Mark and Bodin, François and Beck, Micah and Moore, Terry and Taufer, Michela and Swany, Martin and Vilotte, Jean-Pierre},
	month = jun,
	year = {2021},
	note = {arXiv:2105.10680 [cs.NI]},
	keywords = {Computer Science - Distributed, Parallel, and Cluster Computing, Computer Science - Networking and Internet Architecture},
	annote = {Comment: Updated author list},
	}


